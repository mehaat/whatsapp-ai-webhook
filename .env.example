# --------------------------------------------------------------------------
# ME-HAAT Fashion AI Bot v3.0 - Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# --------------------------------------------------------------------------

# WhatsApp Cloud API webhook verification token (you choose this value,
# then enter the same value in Meta App Dashboard webhook setup)
VERIFY_TOKEN=your_custom_verify_token_here

# WhatsApp Cloud API permanent access token
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here

# WhatsApp Business phone number ID (from Meta App Dashboard)
PHONE_NUMBER_ID=your_phone_number_id_here

# WhatsApp Cloud API version (optional, defaults to v23.0)
WHATSAPP_API_VERSION=v23.0

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (optional, defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# --------------------------------------------------------------------------
# Shopify OAuth App (created via the new Shopify Dev Dashboard)
# --------------------------------------------------------------------------

# Client ID from your Shopify app's API credentials
SHOPIFY_API_KEY=your_shopify_app_client_id

# Client secret from your Shopify app's API credentials
SHOPIFY_API_SECRET=your_shopify_app_client_secret

# Public HTTPS base URL where this app is deployed (no trailing slash),
# e.g. https://mehaat-bot.onrender.com
SHOPIFY_APP_URL=https://your-app.onrender.com

# Comma-separated OAuth scopes requested during installation
SHOPIFY_SCOPES=read_products,read_orders,read_inventory,read_customers,write_draft_orders

# Secret used to validate incoming Shopify webhooks (from app setup)
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# Shopify Admin API version (optional, defaults to 2024-10)
SHOPIFY_API_VERSION=2024-10

# Optional: pin a single default shop domain for single-store deployments
# once it has been installed once via /shopify/install
DEFAULT_SHOP_DOMAIN=your-store.myshopify.com

# Path where the OAuth token store JSON file is persisted.
# On Render, point this at a mounted persistent disk, e.g. /var/data/shop_tokens.json
TOKEN_STORE_PATH=shop_tokens.json

# --------------------------------------------------------------------------
# Server / networking
# --------------------------------------------------------------------------

PORT=5000
REQUEST_TIMEOUT_SECONDS=15
MAX_RETRIES=3
