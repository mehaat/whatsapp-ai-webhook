# --------------------------------------------------------------------------
# ME-HAAT Fashion AI Bot v9.0 Enterprise Edition - Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Every optional setting has a safe default — an existing v4/v5 .env keeps
# working unchanged. All v6 commerce settings are OPTIONAL: the platform runs
# on SQLite with a Manual-UPI payment link and no gateway credentials.
# --------------------------------------------------------------------------

# WhatsApp Cloud API webhook verification token (you choose this value,
# then enter the same value in Meta App Dashboard webhook setup)
VERIFY_TOKEN=your_custom_verify_token_here

# WhatsApp Cloud API permanent access token
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here

# WhatsApp Business phone number ID (from Meta App Dashboard)
PHONE_NUMBER_ID=your_phone_number_id_here

# WhatsApp Cloud API version (optional, defaults to v23.0)
WHATSAPP_API_VERSION=v23.0

# Meta App Secret (App Dashboard -> App settings -> Basic -> App secret).
# When set, inbound webhook POSTs are verified against the X-Hub-Signature-256
# header and forged/unsigned calls are rejected with 403. STRONGLY recommended
# in production. Leave blank to skip verification (a warning is logged).
WHATSAPP_APP_SECRET=

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (optional, defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# --------------------------------------------------------------------------
# Shopify OAuth App (created via the new Shopify Dev Dashboard)
# --------------------------------------------------------------------------

# Client ID from your Shopify app's API credentials
SHOPIFY_API_KEY=your_shopify_app_client_id

# Client secret from your Shopify app's API credentials
SHOPIFY_API_SECRET=your_shopify_app_client_secret

# Public HTTPS base URL where this app is deployed (no trailing slash),
# e.g. https://mehaat-bot.onrender.com
SHOPIFY_APP_URL=https://your-app.onrender.com

# Comma-separated OAuth scopes requested during installation
SHOPIFY_SCOPES=read_products,read_orders,read_inventory,read_customers,write_draft_orders

# Secret used to validate incoming Shopify webhooks (from app setup)
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# Shopify Admin API version (optional, defaults to 2024-10)
SHOPIFY_API_VERSION=2024-10

# Optional: pin a single default shop domain for single-store deployments
# once it has been installed once via /shopify/install
DEFAULT_SHOP_DOMAIN=your-store.myshopify.com

# Path where the OAuth token store JSON file is persisted.
# On Render, point this at a mounted persistent disk, e.g. /var/data/shop_tokens.json
TOKEN_STORE_PATH=shop_tokens.json

# --------------------------------------------------------------------------
# Server / networking
# --------------------------------------------------------------------------

PORT=5000
REQUEST_TIMEOUT_SECONDS=15
MAX_RETRIES=3

# --------------------------------------------------------------------------
# v4.0 optional features (safe to leave at defaults)
# --------------------------------------------------------------------------

# Native WhatsApp Product Messages: set your Meta Commerce catalog id to send
# native product cards. Leave blank to use formatted text product cards.
WHATSAPP_CATALOG_ID=

# After sending product cards, also send a short Gemini styling recommendation.
# Set to "false" to send ONLY the product cards.
PRODUCT_RECO_ENABLED=true

# Log output format: "text" (default, human readable) or "json" (structured).
LOG_FORMAT=text
LOG_LEVEL=INFO

# Optional persistence layer (SQLAlchemy). "false" keeps the in-memory store.
USE_DATABASE=false
# Used only when USE_DATABASE=true. SQLite by default; set a Postgres URL for
# durable multi-worker storage, e.g. postgresql+psycopg2://user:pass@host/db
DATABASE_URL=sqlite:///mehaat.db

# Optional Fernet key to encrypt Shopify access tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to keep plaintext token storage (v3.0 behaviour).
TOKEN_ENCRYPTION_KEY=

# --------------------------------------------------------------------------
# v4.2 Admin Dashboard (login-protected console at /admin) — additive module
# --------------------------------------------------------------------------

# Admin login credentials. Required for the dashboard login to work.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password

# Optional: use a Werkzeug password hash instead of plaintext ADMIN_PASSWORD.
# Generate with:
#   python -c "from werkzeug.security import generate_password_hash as g; print(g('YOUR_PASSWORD'))"
ADMIN_PASSWORD_HASH=

# Stable secret used to sign admin session cookies. STRONGLY recommended in
# production (otherwise a key is derived from the credentials). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_SECRET_KEY=

# Path to the dashboard's own SQLite database. Defaults to a file next to
# TOKEN_STORE_PATH (on Render that means the mounted /var/data disk).
ADMIN_DB_PATH=

# Idle-session timeout in minutes (default 60) and login throttle settings.
ADMIN_SESSION_TIMEOUT_MIN=60
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_SEC=300

# ==========================================================================
# v6.0 Enterprise Commerce (all optional; safe defaults shown)
# ==========================================================================

# Master switch for the whole v6 commerce surface. false => behaves like v5.1.
COMMERCE_ENABLED=true
# Human-facing order number prefix -> MH-2026-000001
ORDER_NUMBER_PREFIX=MH
DEFAULT_CURRENCY=INR
# Shown in the "order confirmed" WhatsApp message.
DELIVERY_ESTIMATE=3-5 Days
# Automatically create a Shopify draft order when a catalog order arrives.
AUTO_DRAFT_ORDER=true
# Validate Shopify stock before accepting an order. Default OFF (fail-open),
# because it needs your WhatsApp catalog retailer-ids to map to Shopify variant
# ids. Turn on once that mapping holds.
STOCK_VALIDATION_ENABLED=false
# WhatsApp number (E.164 digits, no +) that receives new-order admin alerts.
ADMIN_WHATSAPP_NUMBER=

# --- Business identity on PDF invoices ---
BUSINESS_NAME=ME-HAAT Fashion
BUSINESS_ADDRESS=
BUSINESS_GSTIN=
BUSINESS_PHONE=
BUSINESS_EMAIL=
BUSINESS_WEBSITE=https://mehaatfaishon.com
# Absolute path to a PNG logo rendered at the top of invoices (optional).
INVOICE_LOGO_PATH=
# Directory where generated invoice PDFs are written (use the mounted disk on
# Render, e.g. /var/data/invoices).
INVOICE_OUTPUT_DIR=invoices
# Default GST % applied when an order carries no explicit tax, and flat shipping.
TAX_RATE_PERCENT=0
SHIPPING_FLAT=0

# --- Payments (provider adapter; Manual UPI works with no gateway account) ---
# One of: manual_upi | razorpay | stripe | cashfree | phonepe
PAYMENT_PROVIDER=manual_upi
PAYMENT_LINK_EXPIRY_MINUTES=1440
# Manual UPI (builds a upi://pay deep link):
UPI_VPA=
UPI_PAYEE_NAME=ME-HAAT Fashion
# Razorpay (Payment Links API):
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Stripe (Checkout):
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Cashfree (PG orders):
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox
# PhonePe (PG pay):
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=sandbox

# --- Programmatic order/tracking API security ---
# Secret used to sign JWTs issued by POST /api/token. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_EXPIRY_MINUTES=1440
# Optional simple bearer key accepted via the X-API-Key header (alternative to JWT).
API_KEY=

# ==========================================================================
# v6.1 (CRM, RBAC, background jobs, inventory reservation) — all optional
# ==========================================================================

# Background job workers: offload order side effects (draft order, invoice,
# notifications, reservation) so the webhook returns fast. false => run inline.
JOBS_ENABLED=true
JOBS_WORKERS=2
JOBS_MAX_ATTEMPTS=3

# Inventory reservation ledger: reserve on order, release on cancel/refund,
# commit on fulfilment. INVENTORY_SYNC_ENABLED additionally mirrors reservations
# to Shopify inventory (needs the write_inventory scope).
INVENTORY_RESERVATION_ENABLED=true
INVENTORY_SYNC_ENABLED=false

# Default role for newly created dashboard users (viewer|staff|manager|admin|owner).
# The env ADMIN_USERNAME/ADMIN_PASSWORD above is always a built-in "owner".
DEFAULT_ADMIN_ROLE=staff

# ==========================================================================
# v7.0 Enterprise (commerce depth, shipping, security, observability)
# ==========================================================================
COUPONS_ENABLED=true
ABANDONED_CART_HOURS=6
LOW_STOCK_THRESHOLD=3

# Shipping courier: manual | shiprocket | delhivery ("manual" needs no account)
SHIPPING_PROVIDER=manual
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
DELHIVERY_TOKEN=
PICKUP_PINCODE=

# Admin security
ADMIN_2FA_ENABLED=false
# Comma-separated IPs/CIDRs allowed to reach /admin (empty = allow all)
ADMIN_IP_ALLOWLIST=

# Observability
SENTRY_DSN=
METRICS_ENABLED=true
# Optional Redis URL (reserved for a future Celery/RQ queue backend)
REDIS_URL=

# ==========================================================================
# v8.0 Enterprise scale (Celery/Redis, multi-tenant, dev portal, compliance)
# ==========================================================================
# Background queue backend: "inprocess" (default threads) or "celery".
QUEUE_BACKEND=inprocess
# Redis powers Celery + (future) distributed rate limits. Required for celery.
REDIS_URL=
# Optional explicit Celery URLs (default to REDIS_URL when unset).
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Multi-tenant. OFF => single implicit "default" tenant (unchanged behaviour).
MULTI_TENANT_ENABLED=false
DEFAULT_TENANT_SLUG=default

# Developer portal (API key management + Swagger at /developers, /api/docs)
DEVELOPER_PORTAL_ENABLED=true

# Compliance: data retention in days (0 = keep forever) + export directory.
DATA_RETENTION_DAYS=0
COMPLIANCE_EXPORT_DIR=exports

# Monitoring
# SENTRY_DSN / METRICS_ENABLED are defined above (v7). Grafana admin password:
GRAFANA_ADMIN_PASSWORD=admin

# ==========================================================================
# v9.0 (AI commerce, caching/HA, Sentry depth)
# ==========================================================================
# Redis cache + shared rate limiting (falls back to in-memory when Redis down).
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
# Redis HA: Sentinel endpoints (host:port,host:port) + master name, or cluster.
REDIS_SENTINELS=
REDIS_SENTINEL_MASTER=mymaster
REDIS_CLUSTER=false

# Sentry (expanded): environment + trace sampling (SENTRY_DSN defined above).
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Advanced AI Commerce
RECOMMENDATIONS_ENABLED=true
VISUAL_SEARCH_ENABLED=true
AI_STYLIST_ENABLED=true
# Visual embedder: "histogram" (offline, always works) or "gemini" (vision).
VISUAL_EMBEDDER=histogram
GEMINI_VISION_MODEL=gemini-2.5-flash
